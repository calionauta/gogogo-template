#!/bin/bash
set -euo pipefail

PROJECT_DIR="$(git rev-parse --show-toplevel)"
cd "$PROJECT_DIR"

echo "=== Pre-commit checks ==="

# File size check (blocking)
.githooks/check-sizes.sh || exit 2

# Formatting: gofumpt + goimports (blocking — catches issues the full
# gate would catch later, fast enough to run on every commit).
if ! test -z "$(gofumpt -l .)"; then
    echo "❌ gofumpt formatting issues:"
    gofumpt -l .
    echo "   Run: gofumpt -w ."
    exit 2
fi
if ! test -z "$(goimports -l -local github.com/calionauta/gogogo-fullstack-template $(find . -name '*.go' ! -name '*_templ.go'))"; then
    echo "❌ goimports issues:"
    goimports -l -local github.com/calionauta/gogogo-fullstack-template $(find . -name '*.go' ! -name '*_templ.go')
    echo "   Run: goimports -w -local github.com/calionauta/gogogo-fullstack-template ."
    exit 2
fi
echo "✅ formatting clean"

# Datastar lint + CSS rebuild check (only when .templ files changed).
# If a contributor adds a new utility class, the generated CSS will
# be stale; this block regenerates it and aborts the commit if the
# working tree is dirty after, so the regenerated CSS must be staged.
if git diff --cached --name-only | grep -qE '\.(templ|go)$'; then
    bin/datastar-lint || exit 2
    if grep -q "tailwindcss" package.json 2>/dev/null; then
        echo "→ Rebuilding CSS (Tailwind v4 + DaisyUI v5)..."
        if [ -d node_modules ]; then
            npm run build --silent
            if ! git diff --quiet --exit-code web/resources/static/app.min.css 2>/dev/null; then
                echo "❌ CSS is out of date. Run \`make css\` and stage the regenerated file."
                exit 2
            fi
        else
            echo "  ⚠ node_modules not present; run \`make css-install\` first."
        fi
    fi
fi

# go mod tidy check (fail if dirty)
go mod tidy
if ! git diff --exit-code go.mod go.sum >/dev/null 2>&1; then
    echo "❌ go.mod or go.sum is dirty after 'go mod tidy'"
    echo "   Run: go mod tidy && git add go.mod go.sum"
    exit 2
fi
echo "✅ go.mod/go.sum tidy"

# SCOPE annotation linter (only when relevant files are staged).
# Catches the failure mode that drift in inline documentation
# creates: new files in internal/ or features/ added without
# `// SCOPE:layer=…,removal=…` would otherwise pass the linter
# (golangci-lint doesn't know about our taxonomy).
if git diff --cached --name-only | grep -qE '^(internal|features)/.*\.go$'; then
    echo "→ check-scope (SCOPE annotation linter)..."
    go run ./cmd/check-scope || exit 2
fi

# Full lint (blocking — no --fast shortcuts)
if which golangci-lint >/dev/null 2>&1; then
    golangci-lint run ./... --timeout 3m || exit 2
else
    echo "❌ golangci-lint not installed (brew install golangci-lint)"
    exit 2
fi
echo "=== All pre-commit checks passed ==="
