package components

import (
	"encoding/json"
	"fmt"
	"strconv"

	"github.com/calionauta/gogogo-fullstack-template/features/todo"
)

func marshalSignals(s todo.Signals) string {
	b, _ := json.Marshal(s)
	return string(b)
}

templ TodoList(signals todo.Signals) {
	<div class="max-w-2xl mx-auto mt-8 px-4 animate-in fade-in zoom-in-95 animate-duration-500">
		<div class="card bg-base-100 shadow-xl" data-signals={ marshalSignals(signals) } data-on-load={ "@get('/api/todos/stream')" }>
			<div class="card-body">
				<h2 class="card-title text-2xl mb-4">
					<svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-primary" viewBox="0 0 20 20" fill="currentColor">
						<path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/>
					</svg>
					Todo App
					<span class="badge badge-ghost ml-2 text-sm font-normal">{ strconv.Itoa(signals.ItemCount) } items</span>
				</h2>

				<form
					class="join w-full mb-6"
					data-on:submit={ "@post('/api/todos', {contentType: 'form'})" }
				>
					<input
						type="text"
						name="title"
						class="input join-item flex-1"
						placeholder="Add a new todo..."
						data-bind="newTitle"
						autofocus
					/>
					<button type="submit" class="btn btn-primary join-item transition-transform hover:scale-105 active:scale-95" data-disabled="$loading">
						Add
						<span class="loading loading-spinner loading-xs" data-show="$loading"></span>
					</button>
					if signals.LLMEnabled {
						<button
							type="button"
							class="btn btn-secondary join-item"
							data-on:click={ "@post('/api/todos/suggest?clientID=' + $clientID, {contentType: 'form'})" }
							title="Queue a suggest job (real LLM) — result streams back via SSE"
						>
							Suggest
						</button>
					}
									if signals.SimulatedLLM {
						<button
							type="button"
							class="btn btn-accent join-item"
							data-on:click={ "@post('/api/todos/suggest-simulated?clientID=' + $clientID, {contentType: 'form'})" }
							title="Queue a suggest job against an in-process fake LLM (no API key): error → retry → slow"
						>
							Suggest (simulated)
						</button>
					}
					<span class="loading loading-spinner loading-sm" data-show="$suggestPending"></span>
				</form>

				if signals.LLMEnabled && len(signals.Suggestions) > 0 {
					@suggestionsList(signals.Suggestions)
				}
				if signals.LLMEnabled && signals.SuggestErr != "" {
					<div class="alert alert-warning text-sm mb-4" role="alert">
						{ signals.SuggestErr }
					</div>
				}

				<div class="tabs tabs-box mb-4" role="tablist">
				@renderTab("All", "all", signals.Filter, "/api/todos?filter=all")
				@renderTab("Active", "active", signals.Filter, "/api/todos?filter=active")
				@renderTab("Completed", "completed", signals.Filter, "/api/todos?filter=completed")
				</div>

				@TodoListRegion(signals)

				if signals.ItemCount > 0 {
					<div class="flex justify-between items-center mt-4 pt-4 border-t border-base-200">
						<span class="text-sm text-base-content/50" data-text="$itemCount + ' items'">
							{ fmt.Sprintf("%d items", signals.ItemCount) }
						</span>
						<button
							class="btn btn-ghost btn-xs text-error"
							data-on:click="@post('/api/todos/completed/delete')"
						>
							Clear completed
						</button>
					</div>
				}

				if signals.AdminEnabled {
					@adminUnlockForm()
				}

				@TechstackPanel(signals)
			</div>
		</div>

		<div class="toast toast-end" id="retry-toast" data-show="$loading"></div>
	</div>
}

templ TodoListRegion(signals todo.Signals) {
	<div class="divide-y divide-base-200" id="todo-list">
		if len(signals.Todos) == 0 {
			<div class="py-8 text-center text-base-content/40">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 mx-auto mb-3 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
				</svg>
				<p>No todos yet. Add one above!</p>
			</div>
		}
		for _, item := range signals.Todos {
			@TodoItem(item)
		}
	</div>
}

templ renderTab(label, value, current, endpoint string) {
	<a
		href="#"
		role="tab"
		class={ "tab", templ.KV("tab-active", current == value) }
		data-on:click={ "@get('" + endpoint + "')" }
	>
		{ label }
	</a>
}

// TechstackPanel is a collapsible diagnostics section that lets a
// developer exercise and observe each layer of the stack from the todo
// UI:
//   - Realtime: NATS JetStream presence (connected client count).
//   - Queue + retry: enqueues a retry_demo job that fails twice then
//     succeeds, streaming per-attempt feedback to every client.
//   - Durable workflow: fires the Turbine WelcomeOnboarding workflow
//     (only when the binary is built with -tags turbine and
//     WORKFLOW_ENABLED=true).
templ TechstackPanel(signals todo.Signals) {
	<details class="mt-4 pt-4 border-t border-base-200 text-sm">
		<summary class="cursor-pointer font-semibold select-none">Techstack & Diagnostics</summary>
		<div class="flex flex-col gap-3 mt-3">
			<div class="flex items-center gap-2 flex-wrap">
				<span class="badge badge-sm badge-primary">Realtime</span>
				<span class="opacity-70">NATS JetStream — every mutation broadcasts to all clients.</span>
				<span class="badge badge-sm" data-text="$connectedClients + ' online'"></span>
			</div>
			<div class="flex items-center gap-2 flex-wrap">
				<button class="btn btn-sm btn-outline" data-on:click={ "@post('/api/todos/retry-demo')" }>
					Test queue + retry
				</button>
				<span class="text-xs opacity-60 font-mono" data-text="$lastRetry"></span>
			</div>
			if signals.WorkflowEnabled {
				<div class="flex items-center gap-2 flex-wrap">
					<button class="btn btn-sm btn-outline" data-on:click={ "@post('/api/onboarding/start')" }>
						Run durable workflow (Turbine)
					</button>
					<span class="text-xs opacity-60">Creates example todos via a durable workflow; survives restarts.</span>
				</div>
				// Live stepper: advances as each durable step completes and
				// survives a server restart (Turbine replays recorded steps).
				if signals.OnboardingActive && signals.OnboardingTotal > 0 {
					<div class="mt-2 p-3 bg-base-200/40 rounded-lg">
						<div class="text-xs font-semibold mb-2">Durable workflow progress (Turbine + JetStream realtime):</div>
						<ul class="steps steps-vertical w-full">
							for i := 1; i <= signals.OnboardingTotal; i++ {
								<li class={ map[bool]string{true: "step step-primary", false: "step"}[i <= signals.OnboardingStep] }>
									Step { strconv.Itoa(i) }
									if i == signals.OnboardingStep {
										<span class="text-xs opacity-70"> — { signals.OnboardingDetail }</span>
									}
								</li>
							}
						</ul>
						if signals.WorkflowCompleted {
							<div class="mt-2 alert alert-success text-xs py-2">
								<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
								<span>Onboarding workflow completed — 3 example todos created via a durable, restart-tolerant Turbine workflow.</span>
							</div>
						}
					</div>
				}
			}
		</div>
	</details>
}

// adminUnlockForm renders the master-password form. Only mounted when
// signals.AdminEnabled is true (server has ADMIN_UNLOCK_TOKEN configured
// via the age-encrypted secrets file). The form posts to
// /api/admin/unlock, which compares the token constant-time and clears
// all todos on match. Wrong token returns 403.
templ adminUnlockForm() {
	<details class="mt-4 pt-4 border-t border-base-200">
		<summary class="text-sm text-base-content/40 cursor-pointer hover:text-base-content/60">
			Admin unlock
		</summary>
		<form
			class="join w-full mt-2"
			data-on:submit={ "@post('/api/admin/unlock', {contentType: 'form'})" }
		>
			<input
				type="password"
				name="token"
				class="input input-sm join-item flex-1"
				placeholder="Master password"
				required
				autocomplete="off"
			/>
			<button type="submit" class="btn btn-warning btn-sm join-item" data-disabled="$loading">
				Clear all
			</button>
		</form>
	</details>
}

// suggestionsList renders the AI-suggested completions as clickable
// buttons. Clicking a suggestion fills the newTitle signal so the
// user can review and submit.
templ suggestionsList(suggestions []string) {
	<div class="mb-4 p-3 bg-base-200/40 rounded-lg">
		<div class="text-xs text-base-content/50 mb-2">AI suggestions — click to use:</div>
		<div class="flex flex-wrap gap-2">
			for _, s := range suggestions {
				<button
					type="button"
					class="btn btn-xs btn-outline"
					data-on:click={ "$newTitle = " + safeJSString(s) }
				>
					{ s }
				</button>
			}
		</div>
	</div>
}

// safeJSString returns s as a JSON string literal with surrounding
// double quotes, suitable for embedding inside a Datastar
// data-on:click expression. We use strconv.Quote so Go's standard
// escaping handles control characters and quotes consistently.
func safeJSString(s string) string {
	return strconv.Quote(s)
}
